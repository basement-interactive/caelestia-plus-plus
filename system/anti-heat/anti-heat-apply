#!/usr/bin/env bash
# Root half of the "Anti-Heat" feature. Run by anti-heat.service while the
# mode is on.
#
#   run      loop forever, re-applying the heat measures (default)
#   restore  put everything back to stock (service ExecStopPost)
#
# Contract: anti-heat NEVER trades performance for temperature. Every lever
# here cools without lowering ceilings — no STAPM/fast/slow power caps, no
# governor changes, no clock limits. What runs depends on the hardware:
#
#   AMD (SMU accepts it)  Curve Optimizer undervolt via ryzenadj set-coall:
#                         same clocks at lower voltage, conservative -10.
#                         Locked firmware (many OEM BIOSes) rejects it —
#                         logged once, skipped.
#   Intel                 `intel-undervolt apply` when the tool AND its
#                         config exist (we never invent voltage offsets).
#   AMD mobile APU        Tctl overheat guard at 90C: below firmware's
#                         ~100C shutdown, above any healthy sustained load —
#                         it only ever bites when the machine is actually
#                         overheating.
#   ThinkPads             early fan curve (thinkfan-cool): fans lead the
#                         heat instead of chasing it. Pure gain.
#
# Re-applied every 30s because suspend and EC profile events silently reset
# the SMU values to stock.
set -u

# Conservative CO offset: crashes from undervolting show up under LIGHT load
# (idle/browsing), not stress tests. Lower magnitude if a machine misbehaves.
CO_OFFSET=-10
# Overheat guard only — not a performance cap (stock Tctl is 95-100)
GUARD_TCTL=90

CPU_VENDOR=$(awk -F': ' '/vendor_id/{print $2; exit}' /proc/cpuinfo 2>/dev/null || true)

is_laptop() {
    local t
    t=$(cat /sys/class/dmi/id/chassis_type 2>/dev/null || echo 0)
    [[ "$t" =~ ^(8|9|10|11|14|31|32)$ ]] && return 0
    compgen -G "/sys/class/power_supply/BAT*" >/dev/null
}
LAPTOP=false
is_laptop && LAPTOP=true

# ryzenadj set-coall encodes negative offsets as 32-bit two's complement
co_value() {
    printf '0x%08X' $((0x100000000 + $1))
}

# Journal-visible state transitions only (no 30s spam) — a silent ryzenadj
# failure is never acceptable, but a locked SMU should not spam either.
amd_state=""
intel_state=""

apply_amd() {
    [[ "$CPU_VENDOR" == AuthenticAMD ]] || return 0
    command -v ryzenadj >/dev/null || return 0
    local args=(--set-coall="$(co_value $CO_OFFSET)") out
    $LAPTOP && args+=(--tctl-temp="$GUARD_TCTL")
    out=$(ryzenadj "${args[@]}" 2>&1)
    if [[ $? -ne 0 || "$out" =~ [Rr]eject|[Ff]ail|[Uu]nable|[Ee]rror ]]; then
        if [[ "$amd_state" != failed ]]; then
            echo "SMU rejected the undervolt (locked firmware?) — anti-heat continues fan-side only: ${out:0:300}" >&2
            amd_state=failed
        fi
    elif [[ "$amd_state" != ok ]]; then
        echo "applied: Curve Optimizer $CO_OFFSET$($LAPTOP && echo ", Tctl guard ${GUARD_TCTL}C")"
        amd_state=ok
    fi
}

apply_intel() {
    [[ "$CPU_VENDOR" == GenuineIntel ]] || return 0
    command -v intel-undervolt >/dev/null || return 0
    [[ -f /etc/intel-undervolt.conf ]] || return 0
    if intel-undervolt apply >/dev/null 2>&1; then
        if [[ "$intel_state" != ok ]]; then
            echo "applied: intel-undervolt offsets from /etc/intel-undervolt.conf"
            intel_state=ok
        fi
    elif [[ "$intel_state" != failed ]]; then
        echo "intel-undervolt apply failed (locked MSR / plundervolt mitigation?)" >&2
        intel_state=failed
    fi
}

# The early fan curve yields to the stronger ones: bed and max both own the
# fan while they run (thinkfan-cool Conflicts= them, so it is kicked off when
# they start). Once they stop, this reconciler brings the cool curve back.
ensure_fan_curve() {
    [[ -f /etc/thinkfan-cool.yaml ]] || return 0
    if systemctl -q is-active thinkfan-bed.service || systemctl -q is-active thinkfan-max.service; then
        return
    fi
    systemctl -q is-active thinkfan-cool.service || systemctl start thinkfan-cool.service
}

restore() {
    if [[ "$CPU_VENDOR" == AuthenticAMD ]] && command -v ryzenadj >/dev/null; then
        local args=(--set-coall=0x00000000)
        $LAPTOP && args+=(--tctl-temp=95)
        ryzenadj "${args[@]}" >/dev/null 2>&1 || true
    fi
    # intel-undervolt has no unapply; offsets clear on reboot and are tiny.
    # thinkfan-cool is stopped by anti-heat-sync; EC auto fan takes over.
}

case "${1:-run}" in
restore)
    restore
    ;;
run)
    echo "anti-heat starting: laptop=$LAPTOP cpu=${CPU_VENDOR:-unknown}"
    while :; do
        apply_amd
        apply_intel
        ensure_fan_curve
        sleep 30
    done
    ;;
*)
    echo "usage: $0 [run|restore]" >&2
    exit 1
    ;;
esac
