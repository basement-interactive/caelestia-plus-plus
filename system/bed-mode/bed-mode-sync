#!/usr/bin/env bash
# Reconciles bed-mode with the toggle state written by caelestia's battery
# popout (services/BedMode.qml). Run by bed-mode-sync.service, which is
# triggered by bed-mode-sync.path on every write to the state file, and once
# at boot to catch a state left over from before shutdown.
#
# ON:  balanced profile, sensitive fan curve (thinkfan), CPU boost off.
#      Boost-off is what actually curbs the heat: bursty light load boosts
#      single cores to ~4.75GHz at high voltage, which overwhelms a blocked
#      intake even at low overall utilization. Base clocks stay untouched.
# OFF: firmware auto fan, boost back on.
set -euo pipefail

state_file=/home/john/.local/state/caelestia/bed-mode
boost=/sys/devices/system/cpu/cpufreq/boost
state=$(cat "$state_file" 2>/dev/null || true)

if [[ "$state" == "1" ]]; then
    powerprofilesctl set balanced || true
    if [[ -w "$boost" ]]; then
        echo 0 > "$boost"
    fi
    systemctl start thinkfan-bed.service
else
    systemctl stop thinkfan-bed.service
    if [[ -w "$boost" ]]; then
        echo 1 > "$boost"
    fi
fi
