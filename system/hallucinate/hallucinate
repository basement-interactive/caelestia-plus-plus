#!/usr/bin/env python3
"""hallucinate — a one-shot desktop app whose UI *and* backend are dreamed up
live by an LLM.

    hallucinate "basic calculator with weird font"

There is no real application behind the window. Gemini invents the whole UI as
a small set of constrained widgets (so it can't build broken components), and
then *is* the backend: every button press, every Enter, every toggle is sent
back to the model, which returns the next state of the app. Press 2 + 2 = and
the model decides what the display now reads. Nothing is computed locally; it
is hallucination all the way down, and it evaporates when you close the window.

Pure standard library apart from the HTTP call — Tkinter for the UI (a
deliberately basic toolkit), urllib for Gemini.
"""
from __future__ import annotations

import argparse
import json
import os
import queue
import sys
import threading
import urllib.error
import urllib.request

# --------------------------------------------------------------------------- #
# Config                                                                       #
# --------------------------------------------------------------------------- #
# The API key is NEVER stored in this repo (secret scanning would block the
# push, rightly). It is resolved at runtime from, in order: --api-key, the
# GEMINI_API_KEY env var, then a local key file the user/installer drops at
# ~/.config/caelestia/gemini.key. The model is an alias tracking the current
# flash release, so it survives individual versions being retired.
KEY_FILE = os.path.expanduser("~/.config/caelestia/gemini.key")
# flash-LITE honours thinkingBudget:0 (thoughts=0 -> fast, ~2-3s). The plain
# flash alias is a thinking model that ignores the budget, thinks for tens of
# seconds and returns truncated specs (a calculator with no buttons). Lite is
# both faster and more reliable for this constrained schema.
DEFAULT_MODEL = "gemini-flash-lite-latest"
ENDPOINT = "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent"

# The widget vocabulary the model is allowed to use. Small on purpose: a narrow
# palette of well-behaved primitives means the model can only assemble things
# that actually render, however weird the concept.
WIDGET_TYPES = ["label", "button", "entry", "text", "checkbox", "slider"]

RESPONSE_SCHEMA = {
    "type": "object",
    "properties": {
        "title": {"type": "string"},
        "width": {"type": "integer"},
        "height": {"type": "integer"},
        "bg": {"type": "string"},
        # Free-form scratchpad the model owns: hidden app state that has no
        # widget (a secret number, a score, a mode). Rounded-tripped verbatim.
        "memory": {"type": "string"},
        "widgets": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {"type": "string"},
                    "type": {"type": "string", "enum": WIDGET_TYPES},
                    "text": {"type": "string"},
                    "value": {"type": "string"},
                    "checked": {"type": "boolean"},
                    "font": {"type": "string"},
                    "font_size": {"type": "integer"},
                    "bold": {"type": "boolean"},
                    "italic": {"type": "boolean"},
                    "align": {"type": "string", "enum": ["left", "center", "right"]},
                    "fg": {"type": "string"},
                    "bg": {"type": "string"},
                    "row": {"type": "integer"},
                    "col": {"type": "integer"},
                    "colspan": {"type": "integer"},
                    "rowspan": {"type": "integer"},
                    "min": {"type": "number"},
                    "max": {"type": "number"},
                },
                "required": ["id", "type", "row", "col"],
            },
        },
    },
    "required": ["title", "widgets"],
}

SYSTEM_PROMPT = f"""\
You are HALLUCINATE: you are simultaneously the user interface AND the entire \
backend of a small desktop application that does not otherwise exist. You dream \
the app into being and then keep dreaming its behaviour, one interaction at a time.

You describe the app as a grid of widgets. Allowed widget types ONLY:
- label: static text (use for displays, titles, results).
- button: clickable; clicking sends you an event.
- entry: single-line text field the user can type into.
- text: multi-line text field.
- checkbox: on/off; toggling sends you an event.
- slider: numeric; needs min and max; releasing sends you an event.

Layout is a grid: every widget needs row and col (0-based); colspan/rowspan \
optional. Keep it tidy and aligned. Style with: font (family name), font_size, \
bold, italic, align, fg and bg (hex like "#1e1e2e"). Lean into the concept — if \
the concept says weird, be weird (odd fonts, colours, wording).

You ARE the backend. When the user interacts, you receive the current UI (with \
the live values the user has entered) plus the event. You return the COMPLETE \
next UI — recompute results yourself, advance any game, update displays. For a \
calculator, YOU do the arithmetic and put the answer in the display. Never \
assume real code runs; every result is yours to produce.

Rules:
- Keep the same widget `id`s and overall layout across events unless the concept \
genuinely calls for a new screen — only change the values/text that should change.
- Use `memory` for hidden state that has no widget (scores, secrets, modes). \
It is handed back to you next turn; nothing else persists.
- Output ONLY the final JSON. Never write reasoning, explanations, comments or \
placeholder prose inside ANY field. Keep every string short and human-facing.
- `value` is ONLY the current contents of an entry/text/slider. Labels and \
buttons use `text`. Never put anything else in `value`.
- Emit the COMPLETE set of widgets every time (e.g. a calculator needs all its \
digit and operator buttons), not a partial screen.
"""

def _read_key_file() -> str | None:
    try:
        key = open(KEY_FILE, encoding="utf-8").read().strip()
        return key or None
    except OSError:
        return None


def _payload(system: str, user_text: str) -> bytes:
    return json.dumps({
        "system_instruction": {"parts": [{"text": system}]},
        "contents": [{"role": "user", "parts": [{"text": user_text}]}],
        "generationConfig": {
            "responseMimeType": "application/json",
            "responseSchema": RESPONSE_SCHEMA,
            "temperature": 1.0,
            # flash is a thinking model; left on, it reasons *inside* the JSON
            # (dumping prose into string fields and running out of output before
            # finishing the widgets). The schema is simple enough not to need it.
            "thinkingConfig": {"thinkingBudget": 0},
        },
    }).encode()


class GeminiError(RuntimeError):
    pass


def gemini(api_key: str, model: str, user_text: str, timeout: int = 60) -> dict:
    """One structured-output round-trip. Returns the parsed UI spec dict."""
    req = urllib.request.Request(
        ENDPOINT.format(model=model),
        data=_payload(SYSTEM_PROMPT, user_text),
        headers={"Content-Type": "application/json", "x-goog-api-key": api_key},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = json.load(resp)
    except urllib.error.HTTPError as e:
        detail = e.read().decode(errors="replace")[:300]
        raise GeminiError(f"HTTP {e.code}: {detail}") from e
    except (urllib.error.URLError, TimeoutError) as e:
        raise GeminiError(f"network: {e}") from e

    try:
        text = body["candidates"][0]["content"]["parts"][0]["text"]
    except (KeyError, IndexError) as e:
        fb = body.get("promptFeedback") or body.get("error") or body
        raise GeminiError(f"no candidate ({json.dumps(fb)[:200]})") from e
    try:
        return json.loads(text)
    except json.JSONDecodeError as e:
        raise GeminiError(f"model returned non-JSON: {text[:200]}") from e


# --------------------------------------------------------------------------- #
# GUI                                                                          #
# --------------------------------------------------------------------------- #
def _parse_font(w: dict) -> tuple:
    """Turn a widget's font hints into a Tk font tuple (family, size, *styles).

    The model may put everything in `font` ("Papyrus, 20, bold") or split it
    across font/font_size/bold/italic. Both are accepted."""
    family, size = "TkDefaultFont", int(w.get("font_size") or 14)
    styles = []
    raw = w.get("font")
    if isinstance(raw, str) and raw.strip():
        parts = [p.strip() for p in raw.replace(",", " ").split() if p.strip()]
        fam_words = []
        for p in parts:
            if p.isdigit():
                size = int(p)
            elif p.lower() in ("bold", "italic", "roman", "normal", "underline"):
                if p.lower() in ("bold", "italic", "underline"):
                    styles.append(p.lower())
            else:
                fam_words.append(p)
        if fam_words:
            family = " ".join(fam_words)
    if w.get("bold"):
        styles.append("bold")
    if w.get("italic"):
        styles.append("italic")
    return (family, size, *dict.fromkeys(styles))  # dedupe, keep order


def _anchor(align: str) -> str:
    return {"left": "w", "center": "center", "right": "e"}.get(align or "center", "center")


class Hallucination:
    THEME_BG = "#14141c"
    THEME_FG = "#e6e6f0"
    THEME_ACCENT = "#2a2a3a"

    def __init__(self, concept: str, api_key: str, model: str):
        import tkinter as tk  # imported here so --dry-run needs no display/tk
        self.tk = tk
        self.concept = concept
        self.api_key = api_key
        self.model = model
        self.spec: dict = {}
        self.memory = ""
        self.widgets: dict[str, dict] = {}
        self.busy = False

        self.root = tk.Tk()
        self.root.title("hallucinate · dreaming…")
        self.root.configure(bg=self.THEME_BG)
        self.root.geometry("360x520")
        self.root.minsize(200, 160)
        self.frame = tk.Frame(self.root, bg=self.THEME_BG)
        self.frame.pack(fill="both", expand=True)

        self._splash("Hallucinating your app…")
        # Worker threads never touch Tk directly (Tk is single-threaded and
        # calling into it off the main thread crashes). They drop results on a
        # queue that a main-thread poller drains.
        self._queue = queue.Queue()
        self.root.after(60, self._drain)
        # First dream happens off the UI thread so the window paints immediately.
        self._run_async(f"Create the initial app for this concept: {self.concept!r}")

    # -- async plumbing ---------------------------------------------------- #
    def _run_async(self, user_text: str) -> None:
        self.busy = True
        self._set_title_busy(True)

        def work():
            try:
                self._queue.put(("ok", gemini(self.api_key, self.model, user_text)))
            except GeminiError as e:
                self._queue.put(("err", str(e)))

        threading.Thread(target=work, daemon=True).start()

    def _drain(self) -> None:
        try:
            kind, payload = self._queue.get_nowait()
        except queue.Empty:
            pass
        else:
            (self._apply if kind == "ok" else self._error)(payload)
        self.root.after(60, self._drain)

    def _set_title_busy(self, on: bool) -> None:
        base = self.spec.get("title") or "hallucinate"
        self.root.title(f"{base} · hallucinating…" if on else base)

    # -- request building -------------------------------------------------- #
    def _event(self, widget_id: str, kind: str) -> None:
        if self.busy:
            return
        self._collect_values()
        req = {
            "app_concept": self.concept,
            "current_ui": self.spec,
            "memory": self.memory,
            "event": {"widget_id": widget_id, "type": kind},
        }
        self._run_async(
            "Here is the current app state and the user's interaction. Return the "
            "full next UI.\n" + json.dumps(req)
        )

    def _collect_values(self) -> None:
        """Read live widget values back into self.spec before sending to the model."""
        for wspec in self.spec.get("widgets", []):
            rec = self.widgets.get(wspec.get("id"))
            if not rec:
                continue
            t, var, w = wspec["type"], rec.get("var"), rec["w"]
            if t == "entry" and var is not None:
                wspec["value"] = var.get()
            elif t == "text":
                wspec["value"] = w.get("1.0", "end-1c")
            elif t == "checkbox" and var is not None:
                wspec["checked"] = bool(var.get())
            elif t == "slider" and var is not None:
                wspec["value"] = str(var.get())

    # -- rendering --------------------------------------------------------- #
    def _splash(self, msg: str) -> None:
        for c in self.frame.winfo_children():
            c.destroy()
        self.widgets.clear()
        lbl = self.tk.Label(self.frame, text=msg, bg=self.THEME_BG, fg=self.THEME_FG,
                            font=("TkDefaultFont", 13), wraplength=320, justify="center")
        lbl.place(relx=0.5, rely=0.5, anchor="center")

    def _error(self, msg: str) -> None:
        self.busy = False
        self._set_title_busy(False)
        self._splash(f"⚠ hallucination failed\n\n{msg}\n\nClose and try again.")

    def _apply(self, spec: dict) -> None:
        self.busy = False
        self.memory = spec.get("memory", self.memory)
        same = self._same_shape(spec)
        self.spec = spec
        if same:
            self._update_in_place(spec)
        else:
            self._rebuild(spec)
        self._set_title_busy(False)
        bg = self._color(spec.get("bg"), self.THEME_BG)
        self.root.configure(bg=bg)
        self.frame.configure(bg=bg)
        w, h = spec.get("width"), spec.get("height")
        if isinstance(w, int) and isinstance(h, int) and self._first_geometry:
            self.root.geometry(f"{max(w,200)}x{max(h,160)}")
            self._first_geometry = False

    _first_geometry = True

    def _same_shape(self, spec: dict) -> bool:
        old = [(w.get("id"), w.get("type")) for w in self.spec.get("widgets", [])]
        new = [(w.get("id"), w.get("type")) for w in spec.get("widgets", [])]
        return bool(old) and old == new

    def _rebuild(self, spec: dict) -> None:
        for c in self.frame.winfo_children():
            c.destroy()
        self.widgets.clear()
        rows, cols = set(), set()
        for wspec in spec.get("widgets", []):
            self._build_widget(wspec)
            rows.add(wspec.get("row", 0))
            cols.add(wspec.get("col", 0))
        for r in rows:
            self.frame.rowconfigure(r, weight=1)
        for c in cols:
            self.frame.columnconfigure(c, weight=1)

    def _update_in_place(self, spec: dict) -> None:
        for wspec in spec.get("widgets", []):
            rec = self.widgets.get(wspec["id"])
            if rec:
                self._style_widget(rec["w"], rec["type"], wspec, rec.get("var"))

    # -- widget factory ---------------------------------------------------- #
    def _build_widget(self, wspec: dict) -> None:
        tk = self.tk
        t = wspec["type"]
        var = None
        if t == "label":
            w = tk.Label(self.frame)
        elif t == "button":
            wid = wspec["id"]
            w = tk.Button(self.frame, takefocus=0,
                          command=lambda i=wid: self._event(i, "click"))
        elif t == "entry":
            var = tk.StringVar(value=str(wspec.get("value", "")))
            w = tk.Entry(self.frame, textvariable=var)
            w.bind("<Return>", lambda _e, i=wspec["id"]: self._event(i, "submit"))
        elif t == "text":
            w = tk.Text(self.frame, height=6, wrap="word")
            w.insert("1.0", str(wspec.get("value", "")))
        elif t == "checkbox":
            var = tk.IntVar(value=1 if wspec.get("checked") else 0)
            w = tk.Checkbutton(self.frame, variable=var, takefocus=0,
                               command=lambda i=wspec["id"]: self._event(i, "toggle"))
        elif t == "slider":
            lo = float(wspec.get("min", 0)); hi = float(wspec.get("max", 100))
            var = tk.DoubleVar(value=float(wspec.get("value") or lo))
            w = tk.Scale(self.frame, from_=lo, to=hi, orient="horizontal",
                         variable=var, takefocus=0, highlightthickness=0)
            w.bind("<ButtonRelease-1>", lambda _e, i=wspec["id"]: self._event(i, "change"))
        else:
            return

        self._style_widget(w, t, wspec, var)
        w.grid(
            row=int(wspec.get("row", 0)), column=int(wspec.get("col", 0)),
            columnspan=int(wspec.get("colspan", 1)), rowspan=int(wspec.get("rowspan", 1)),
            sticky="nsew", padx=3, pady=3,
        )
        self.widgets[wspec["id"]] = {"w": w, "type": t, "var": var}

    def _style_widget(self, w, t: str, wspec: dict, var) -> None:
        tk = self.tk
        fg = self._color(wspec.get("fg"), self.THEME_FG)
        bg = self._color(wspec.get("bg"), self.THEME_ACCENT if t == "button" else self.THEME_BG)
        font = _parse_font(wspec)
        text = str(wspec.get("text", ""))
        try:
            if t in ("label", "button", "checkbox"):
                w.configure(text=text, font=font, fg=fg, bg=bg)
                if t == "label":
                    w.configure(anchor=_anchor(wspec.get("align")), justify="left")
                if t == "button":
                    w.configure(activebackground=fg, activeforeground=bg, relief="flat",
                                highlightthickness=0, bd=0)
                if t == "checkbox":
                    w.configure(selectcolor=bg, activebackground=bg, indicatoron=True)
            elif t == "entry":
                w.configure(font=font, fg=fg, bg=bg, insertbackground=fg,
                            justify=(wspec.get("align") or "left"), relief="flat")
                if var is not None and var.get() != str(wspec.get("value", var.get())):
                    var.set(str(wspec.get("value", "")))
                elif var is not None and "value" in wspec:
                    var.set(str(wspec["value"]))
            elif t == "text":
                w.configure(font=font, fg=fg, bg=bg, insertbackground=fg, relief="flat")
                if "value" in wspec:
                    w.delete("1.0", "end")
                    w.insert("1.0", str(wspec["value"]))
            elif t == "slider":
                w.configure(font=font, fg=fg, bg=bg, troughcolor=self.THEME_ACCENT)
        except tk.TclError:
            # A bad colour/font name from the model must never crash the app.
            try:
                w.configure(fg=self.THEME_FG, bg=self.THEME_BG,
                            font=("TkDefaultFont", 14),
                            **({"text": text} if t in ("label", "button", "checkbox") else {}))
            except tk.TclError:
                pass

    def _color(self, value, fallback: str) -> str:
        if not isinstance(value, str) or not value.strip():
            return fallback
        v = value.strip()
        probe = self.tk
        try:
            # Validate against Tk's colour parser without leaving a widget behind.
            self.root.winfo_rgb(v)
            return v
        except probe.TclError:
            return fallback

    def run(self) -> None:
        self.root.mainloop()


# --------------------------------------------------------------------------- #
def main() -> int:
    ap = argparse.ArgumentParser(
        prog="hallucinate",
        description="Open a one-shot app whose UI and backend are hallucinated live by AI.",
    )
    ap.add_argument("concept", nargs="?", help='what to dream up, e.g. "basic calculator with weird font"')
    ap.add_argument("--model", default=os.environ.get("HALLUCINATE_MODEL", DEFAULT_MODEL))
    ap.add_argument("--api-key", default=None)
    ap.add_argument("--dry-run", action="store_true", help="print the initial UI spec as JSON and exit (no window)")
    args = ap.parse_args()

    if not args.concept:
        ap.print_help(sys.stderr)
        return 1
    api_key = args.api_key or os.environ.get("GEMINI_API_KEY") or _read_key_file()
    if not api_key:
        print(f"hallucinate: no API key. Set GEMINI_API_KEY, pass --api-key, "
              f"or write it to {KEY_FILE}", file=sys.stderr)
        return 1

    if args.dry_run:
        try:
            spec = gemini(api_key, args.model,
                          f"Create the initial app for this concept: {args.concept!r}")
        except GeminiError as e:
            print(f"hallucinate: {e}", file=sys.stderr)
            return 1
        print(json.dumps(spec, indent=2))
        return 0

    try:
        app = Hallucination(args.concept, api_key, args.model)
    except ImportError:
        print("hallucinate: Tkinter is not available — install the 'tk' package "
              "(pacman -S tk)", file=sys.stderr)
        return 1
    app.run()
    return 0


if __name__ == "__main__":
    sys.exit(main())
