[Unit]
Description=Dynamic power-mode picker (auto-selects the ppd profile from live load)
After=power-profiles-daemon.service
Wants=power-profiles-daemon.service

[Service]
Type=simple
ExecStart=/usr/local/bin/dynamic-apply run
ExecStopPost=/usr/local/bin/dynamic-apply restore
Restart=on-failure
RestartSec=2
