#!/usr/bin/env bash
# Polycarbon — the Caelestia++ Windows app runner. Like glass, but fake:
# looks and feels like the real thing.
# Registered as the double-click handler
# for .exe/.msi (see register.sh); everything needed to run the file is set
# up on the spot, silently:
#
#   - the runtime (Kron4ek's wine-staging build, wow64: runs 64- and 32-bit
#     apps) is downloaded into ~/.local/share/caelestia/polycarbon and kept
#     on the LATEST release automatically — a background-quiet daily check
#     picks up new builds and migrates the environment in place
#   - one shared prefix is initialised without any dialogs, with the Windows
#     user folders (Documents, Downloads, Desktop…) pointed straight at the
#     real Linux ones and the whole home tree reachable as H:\
#   - the full compatibility stack goes in unattended: mono (.NET), gecko
#     (embedded HTML), and on Vulkan-capable machines DXVK (Direct3D 8-11)
#     and VKD3D-Proton (Direct3D 12); without Vulkan those two are skipped
#     and the GL renderer carries D3D instead
#   - a runtime-library layer (winetricks: the VC++ runtimes, core fonts,
#     the D3D shader compiler and more) so far more real programs just run
#   - after an installer finishes, the Start Menu / Desktop shortcuts it
#     created are turned into real Linux launchers, so installed programs
#     show up in the app menu exactly like they would on Windows
#
# The plumbing never surfaces: no update dialogs, no crash dialogs, no
# runner-branded menu entries — user-facing text only ever says Polycarbon.
# Everything is user-level; downloads are verified against the release's
# published sha256sums. Progress and failures surface as desktop
# notifications, never as terminal output or dialogs.
set -u

# Always Kron4ek's builds, always the latest wine-staging release. Staging —
# not the Proton line: Proton is Valve's gaming Wine and its fullscreen/DPI
# hack patches broke real desktop apps (Telegram fastfailed with c0000409
# right after EnableNonClientDpiScaling on a mixed-DPI multi-monitor host —
# an app verified working on staging). Same lesson as the original Soda
# runner: gaming builds sacrifice desktop-app correctness. Staging is current,
# complete, and still fsync-enabled; the one thing Proton had over it
# (Windows.Gaming.Input's NonRoamableId, stubbed in staging) is covered by
# the wgi_off recovery rung. Version tags only (X.Y); proton-*/exp/beta
# releases are excluded.
RUNNER_REPO="Kron4ek/Wine-Builds"
RUNNER_TAG_PATTERN='^[0-9]+\.[0-9]+$'
RUNNER_FLAVOR="staging-amd64-wow64"
RUNNER_CHECK_SECONDS=86400

# Bump when anything in the component set below changes; installed prefixes
# catch up on their next launch
COMPONENTS_VER="2026-07-21b"
# The winetricks runtime-library layer, tracked separately so its verb set
# can grow without re-running the heavier component install
BINDINGS_VER="2026-07-21"
WINETRICKS_VER="20260125"
WINETRICKS_URL="https://raw.githubusercontent.com/Winetricks/winetricks/${WINETRICKS_VER}/src/winetricks"
WINETRICKS_SHA256="431f82fc74000e6c864409f1d8fb495d696c03928808e3e8acffc45179312a7b"
# Reliable, non-interactive verbs most Windows software expects to find.
# vcrun2022 is the unified VC++ 2015-2022 runtime and CONFLICTS with the
# 2015/2017/2019 verbs, so only it is listed for that era; vcrun2013 and
# vcrun2010 are separate older runtimes. .NET is covered by wine-mono, so
# winetricks' heavy dotnet verbs are left out on purpose. Each verb is
# best-effort — a failure never blocks a run.
WINETRICKS_VERBS="corefonts vcrun2022 vcrun2013 vcrun2010 d3dcompiler_47 d3dx9"
DXVK_VER="3.0.2"
DXVK_URL="https://github.com/doitsujin/dxvk/releases/download/v${DXVK_VER}/dxvk-${DXVK_VER}.tar.gz"
DXVK_SHA256="9c538924110a7cdef871ca36dee218c0774124374ffdeb38af4b76be55bdf7c2"
VKD3D_VER="3.0.1"
VKD3D_URL="https://github.com/HansKristian-Work/vkd3d-proton/releases/download/v${VKD3D_VER}/vkd3d-proton-${VKD3D_VER}.tar.zst"
VKD3D_SHA256="3cf2315522af5e43605ef6d3c41dad91387040bf97199934f3f7ab76caaa2f0c"
MONO_VER="8.1.0"
MONO_URL="https://dl.winehq.org/wine/wine-mono/${MONO_VER}/wine-mono-${MONO_VER}-x86.msi"
MONO_SHA256="0ed3ec533aef79b2f312155931cf7b1080009ac0c5b4c2bcfeb678ac948e0810"
GECKO_VER="2.47.4"
GECKO_URL="https://dl.winehq.org/wine/wine-gecko/${GECKO_VER}/wine-gecko-${GECKO_VER}"
GECKO64_SHA256="e590b7d988a32d6aa4cf1d8aa3aa3d33766fdd4cf4c89c2dcc2095ecb28d066f"
GECKO32_SHA256="26cecc47706b091908f7f814bddb074c61beb8063318e9efc5a7f789857793d6"

SELF=$(realpath "$0")
# Harvested launchers live flat here with a polycarbon- name prefix, so their
# desktop IDs stay simple and every launcher/menu finds them
APPS_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
BASE="${XDG_DATA_HOME:-$HOME/.local/share}/caelestia/polycarbon"
# Pre-rename installs keep their runner, prefix and apps — just moved over
OLD_BASE="${XDG_DATA_HOME:-$HOME/.local/share}/caelestia/winrun"
[ -d "$OLD_BASE" ] && [ ! -d "$BASE" ] && mv "$OLD_BASE" "$BASE"
mkdir -p "$BASE"
RUNNER_DIR="$BASE/runner"
WINE="$RUNNER_DIR/bin/wine"
export WINEPREFIX="$BASE/prefix"
LOG="$BASE/last-run.log"
PREV_LOG="$BASE/previous-run.log"

notify() { # title body [icon]
    command -v notify-send >/dev/null && notify-send -a "Polycarbon" -i "${3:-application-x-executable}" "$1" "$2"
}

# Every step polycarbon takes is timestamped into the log, so even a hard
# crash leaves a trail of exactly how far it got. The log is on disk and
# append-flushed, so it survives the program (or wine) dying.
logmsg() {
    printf '[%s] polycarbon: %s\n' "$(date '+%H:%M:%S')" "$1" >> "$LOG"
    say "$1"
}

# A fatal setup error is logged, surfaced as a notification WITH the reason,
# and left in the log for later
die() {
    logmsg "FATAL: $1 — $2"
    notify "$1" "$2
Log: $LOG" dialog-error
    exit 1
}

say() { # --setup runs stream stdout into the scan's fix card
    [ "${SETUP_MODE:-}" = 1 ] && echo "$1"
    return 0
}

# Start a fresh log for this run, keeping the previous one so a crash's log
# isn't lost the moment the user retries
new_log() {
    [ -f "$LOG" ] && mv -f "$LOG" "$PREV_LOG" 2>/dev/null
    : > "$LOG"
    logmsg "polycarbon $(cat "$BASE/runner.version" 2>/dev/null || echo 'not installed'), pid $$"
}

# Pull the most diagnostic lines out of a run's log — a Rust panic (with its
# file:line and reason), a WinRT/COM "not implemented", an unhandled
# exception, a wine loader/seh error, a missing DLL or file. Whole lines are
# kept (not just the matched word) so the message reads like the real error;
# the last couple are joined for context. Empty when nothing notable was
# logged, i.e. a clean exit.
# $1: which log slice to read (default the whole run log). The recovery loop
# passes a per-attempt slice so an earlier crash's error never taints the
# verdict on a later, working attempt.
salient_error() {
    # DXVK/VKD3D print "info:"/"warn:" chatter (incl. benign "could not open
    # registry key") and wine emits "NNNN:fixme:" — none of that is a failure.
    # Telegram's SetThreadpool* "DLL Error" lines are its own non-fatal probes.
    # 'dll error'/'init error' are deliberately NOT matched: apps (Telegram)
    # log those non-fatally on every start, so they'd flag a working program.
    grep -aiE 'panicked at|thread .main.* panicked|called .Result::|Err value|not implemented|unhandled exception|err:(seh|module|winediag):|error while loading|shellexecuteex? failed|[a-z0-9_]+\.dll.*(missing|not found|failed to)|could not load|no such file|access is denied|application error|fatal error' "${1:-$LOG}" 2>/dev/null \
        | grep -aivE '^(info|warn|debug):|^[0-9a-f]{2,}:(fixme|trace|warn)|WINEDEBUG=' \
        | tail -2 | sed 's/^[[:space:]]*//' | tr '\n' ' ' | cut -c1-240
}

# A Windows program's real crash reason is usually in ITS OWN log next to the
# exe (Telegram's log.txt, an *.log, a crash dump), which our capture of
# wine's stdout never sees. On a failure, fold those — only the ones this run
# touched — into our log, so "cat last-run.log" shows the program's own error,
# not just our vantage point. Also surfaces the GPUs in play, since graphics
# crashes are common on multi-GPU machines.
collect_app_logs() {
    local dir=$1 marker=$2 f found=""
    while IFS= read -r f; do
        found=1
        case "${f,,}" in
        *.dmp)
            logmsg "app crash dump present: ${f#"$dir"/}"
            ;;
        *)
            logmsg "--- ${f#"$dir"/} (the program's own log) ---"
            tail -50 "$f" >> "$LOG" 2>/dev/null
            ;;
        esac
    done < <(find "$dir" -maxdepth 3 -type f \( -iname '*.log' -o -iname 'log*.txt' -o -iname '*.dmp' \) -newer "$marker" 2>/dev/null | head -4)
    grep -aoE 'Found device: .*' "$LOG" 2>/dev/null | sort -u | while IFS= read -r d; do logmsg "GPU seen — $d"; done
    [ -n "$found" ]
}

export WINEDEBUG="-all"
export WINEFSYNC=1

# Per-machine tuning hook. Anything exported in this file applies to every
# program and can override the defaults above — the escape hatch for hardware
# quirks a shared default can't guess. Examples (uncomment in the file):
#   export DRI_PRIME=1          # force the discrete GPU on a multi-GPU box
#   export WINEFSYNC=0          # if fsync misbehaves on this kernel
#   export MESA_VK_DEVICE_SELECT=list   # print Vulkan devices to the log
# Absent/empty by default, so it changes nothing until a fix is put there.
POLY_ENV="$BASE/env"
if [ ! -f "$POLY_ENV" ]; then
    cat > "$POLY_ENV" <<'ENVTPL'
# Polycarbon per-machine tuning. Uncomment a line to apply it to every
# Windows program. Nothing here is set by default. Try these top-to-bottom
# if a program crashes at startup on this machine.

# 1. Multi-GPU machine (a discrete card + integrated graphics)? If apps crash
#    at startup or render on the wrong GPU, force the discrete one:
#export DRI_PRIME=1

# 2. Still crashing at graphics init? Route Direct3D through OpenGL instead of
#    Vulkan (skips DXVK/VKD3D — slower for games, but dodges Vulkan/multi-GPU
#    driver bugs):
#export WINEDLLOVERRIDES="d3d9,d3d10core,d3d11,dxgi=b"

# 3. fsync misbehaving on this kernel (rare crashes at launch)?
#export WINEFSYNC=0

# Write the list of Vulkan devices into last-run.log for diagnosis:
#export MESA_VK_DEVICE_SELECT=list
ENVTPL
fi
[ -f "$POLY_ENV" ] && . "$POLY_ENV"

fetch() { # url sha256 dest
    curl -fsSL --retry 3 -o "$3" "$1" || die "Download failed" "$1 — check your connection and try again"
    echo "$2  $3" | sha256sum -c --quiet - || {
        rm -f "$3"
        die "Download corrupted" "Checksum mismatch on $(basename "$3") — try again"
    }
}

vulkan_ok() {
    ls /usr/share/vulkan/icd.d/*.json >/dev/null 2>&1
}

# --- Self-recovery ---------------------------------------------------------
# When a program crashes on launch, polycarbon walks a ladder of known Wine
# quirks — each a small environment tweak — restarting the program with one
# applied at a time until it stays up. The tweak that works is saved per
# program, so from then on it launches clean with no crash and no retry
# (prevention). Every step is env-only and scoped to that one launch, so a
# fix for one program never touches another.
#
# Each step: a guard (is it relevant to THIS crash?), a one-line human name,
# and the env it exports. Ordered most-likely / least-invasive first.
QUIRKS_DIR="$BASE/quirks"

# All the detectors read a log slice ($2/$1 = the current attempt's slice,
# default whole log) so recovery judges each attempt on its own output.
gpu_count() { grep -acE '^info:  Found device: ' "${1:-$LOG}"; }

# Does the slice look like it died in graphics/GPU init?
graphics_crash() {
    grep -aqiE 'Found device:|DXVK|vkd3d|vulkan|d3d1[012]|dxgi|Process set as DPI|Renderer' "${1:-$LOG}"
}

wgi_crash() {
    grep -aqE 'windows_wgi.*panicked|NonRoamableId|HRESULT\(0x80004001\)' "${1:-$LOG}"
}

# id, log-slice  ->  guard exit status (0 = try this step for the current crash)
recovery_guard() {
    local slice=${2:-$LOG}
    case $1 in
    gpu_prime) [ "$(gpu_count "$slice")" -ge 2 ] ;;    # 2+ GPUs: force the discrete one
    dxvk_off)  graphics_crash "$slice" ;;              # graphics death: D3D over GL, not Vulkan
    wgi_off)   wgi_crash "$slice" ;;                   # gamepad-API panic
    fsync_off) true ;;                                  # kernel sync issues: last simple lever
    combined)  true ;;                                  # everything applicable at once
    gpu_soft)  graphics_crash "$slice" ;;              # graphics death: CPU rendering, no GPU at all
    esac
}

recovery_human() {
    case $1 in
    gpu_prime) echo "use the discrete GPU" ;;
    dxvk_off)  echo "run Direct3D on OpenGL" ;;
    wgi_off)   echo "disable the crashing gamepad API" ;;
    fsync_off) echo "turn off fsync" ;;
    combined)  echo "all compatibility fixes together" ;;
    gpu_soft)  echo "render without the GPU (slower, but reliable)" ;;
    esac
}

# id, log-slice -> env line(s). combined = union of the applicable singles.
recovery_env() {
    local slice=${2:-$LOG}
    case $1 in
    gpu_prime) echo 'export DRI_PRIME=1' ;;
    dxvk_off)  echo 'export WINEDLLOVERRIDES="${WINEDLLOVERRIDES:+$WINEDLLOVERRIDES;}d3d9,d3d10core,d3d11,d3d12,d3d12core,dxgi=b"' ;;
    wgi_off)   echo 'export WINEDLLOVERRIDES="${WINEDLLOVERRIDES:+$WINEDLLOVERRIDES;}windows.gaming.input="' ;;
    fsync_off) echo 'export WINEFSYNC=0 WINEESYNC=0' ;;
    # Last resort for a graphics crash: no GPU in the picture at all. D3D on
    # OpenGL, OpenGL on Mesa's CPU rasteriser. Slow but sidesteps every GPU /
    # multi-GPU / driver bug — a program that renders anything renders here.
    gpu_soft)  echo 'export LIBGL_ALWAYS_SOFTWARE=1 GALLIUM_DRIVER=llvmpipe WINEDLLOVERRIDES="${WINEDLLOVERRIDES:+$WINEDLLOVERRIDES;}d3d9,d3d10core,d3d11,d3d12,d3d12core,dxgi=b"' ;;
    combined)
        recovery_guard gpu_prime "$slice" && recovery_env gpu_prime
        recovery_guard dxvk_off "$slice" && recovery_env dxvk_off
        recovery_guard wgi_off "$slice" && recovery_env wgi_off
        recovery_env fsync_off
        ;;
    esac
}

# Newest release tag of the chosen line, empty on network failure. The
# Proton builds live in their own tags (not releases/latest), so scan the
# release list — newest first — for the first stable-pattern match.
runner_latest_tag() {
    curl -fsSL --max-time 8 "https://api.github.com/repos/$RUNNER_REPO/releases?per_page=30" 2>/dev/null \
        | grep -oE '"tag_name": *"[^"]+"' | cut -d'"' -f4 | grep -E "$RUNNER_TAG_PATTERN" | head -1
}

# Download and swap in the given release. Integrity comes from the release's
# own published sha256sums.txt rather than a hash baked in here — that is
# what makes always-latest possible while still refusing a corrupt download.
runner_install_tag() {
    local tag=$1
    local asset="wine-$tag-$RUNNER_FLAVOR.tar.xz"
    local base_url="https://github.com/$RUNNER_REPO/releases/download/$tag"
    say "downloading runtime $tag (~95 MB)..."
    curl -fsSL --retry 3 -o "$BASE/runner.tar.xz" "$base_url/$asset" || die "Runtime download failed" "Check your connection and try again"
    local want
    want=$(curl -fsSL --max-time 15 "$base_url/sha256sums.txt" 2>/dev/null | awk -v a="$asset" '$2 == a || $2 == "./"a {print $1}')
    if [ -n "$want" ]; then
        echo "$want  $BASE/runner.tar.xz" | sha256sum -c --quiet - || {
            rm -f "$BASE/runner.tar.xz"
            die "Runtime download corrupted" "Checksum mismatch — try again"
        }
    fi
    rm -rf "$RUNNER_DIR.new"
    mkdir -p "$RUNNER_DIR.new"
    tar -xJf "$BASE/runner.tar.xz" --strip-components=1 -C "$RUNNER_DIR.new" || die "Runtime unpack failed" "See $LOG"
    rm -rf "$RUNNER_DIR"
    mv "$RUNNER_DIR.new" "$RUNNER_DIR"
    echo "$tag" > "$BASE/runner.version"
    rm -f "$BASE/runner.tar.xz"
    needs_reboot=1
}

install_runner() {
    [ -x "$WINE" ] && return 0
    notify "Setting up Windows apps" "One-time download of the runtime (~95 MB)…" folder-download
    local tag
    tag=$(runner_latest_tag)
    [ -n "$tag" ] || die "Cannot reach the update server" "The first-time setup needs internet — try again once online"
    runner_install_tag "$tag"
    needs_reboot="" # fresh install, nothing to migrate
}

# Latest-release check. Time-throttled for normal launches ($1 = "force"
# from --setup bypasses the throttle). Skipped while any app is running on
# the prefix (swapping the runtime under a live process would corrupt it).
# The throttle stamp is set ONLY on a definitive outcome — up-to-date or a
# completed update — so a network failure or a deferral (app running) retries
# on the very next launch instead of being suppressed for a day.
check_runner_update() {
    local force=${1:-}
    local stamp="$BASE/.update-check"
    # A runner from a DIFFERENT line (the configured build just changed — e.g.
    # proton -> staging) must switch on the next launch, not wait out the daily
    # throttle: its version won't match the current line's tag pattern.
    local installed; installed=$(cat "$BASE/runner.version" 2>/dev/null)
    if [ -n "$installed" ] && ! printf '%s' "$installed" | grep -qE "$RUNNER_TAG_PATTERN"; then
        force=force
        say "runtime is from a superseded build ($installed) — switching lines now"
    fi
    if [ "$force" != "force" ] && [ -f "$stamp" ]; then
        local age=$(( $(date +%s) - $(stat -c %Y "$stamp" 2>/dev/null || echo 0) ))
        [ "$age" -lt "$RUNNER_CHECK_SECONDS" ] && return 0
    fi
    local tag
    tag=$(runner_latest_tag)
    [ -n "$tag" ] || return 0                     # offline — no stamp, retry next launch
    echo "$tag" > "$BASE/.latest-tag"             # let the scan surface "update available"
    if [ "$tag" = "$(cat "$BASE/runner.version" 2>/dev/null)" ]; then
        touch "$stamp"                            # up to date — throttle the next check
        return 0
    fi
    # Never swap the runtime out from under a live app. But a wineserver that
    # just lost its last client lingers idle for a few seconds — that is NOT a
    # running app, so give it a moment to exit before deciding to defer (its
    # stale clients were already cleared at launch). A real app keeps it alive
    # and we defer to the next idle launch.
    local waited=0
    while pgrep -f "$RUNNER_DIR/bin/wineserver" >/dev/null 2>&1; do
        [ "$waited" -ge 6 ] && {
            say "runtime $tag available - applied on next launch (an app is running now)"
            return 0
        }
        sleep 1
        waited=$((waited + 1))
    done
    notify "Updating Windows apps" "New runtime $tag — a moment…" folder-download
    runner_install_tag "$tag"
    touch "$stamp"
}

needs_reboot=""

# wineboot runs with no display attached so its "updating configuration"
# splash physically cannot appear — the registry/DLL work is all headless
_silent_wineboot() { # -i | -u
    env -u DISPLAY -u WAYLAND_DISPLAY WINEDLLOVERRIDES="mscoree=;mshtml=" "$RUNNER_DIR/bin/wineboot" "$1" >>"$LOG" 2>&1
}

# The plumbing must never announce itself: no crash-handler dialog (failures
# already surface as a Polycarbon notification), and prefix updates are done
# proactively here so an app launch can never trigger the update splash.
_quiet_runtime_ui() {
    "$WINE" reg add 'HKCU\Software\Wine\WineDbg' /v ShowCrashDialog /t REG_DWORD /d 0 /f >>"$LOG" 2>&1
}

init_prefix() {
    if [ -f "$WINEPREFIX/system.reg" ]; then
        # Existing prefix, but the runtime just changed under it — migrate the
        # prefix in place (updates system DLLs) without wiping user data
        if [ -n "$needs_reboot" ]; then
            say "migrating the Windows environment to the new runtime..."
            _silent_wineboot -u || true
            "$RUNNER_DIR/bin/wineserver" -w
            _quiet_runtime_ui
        fi
        return 0
    fi
    say "preparing the shared Windows environment..."
    notify "Preparing Windows environment" "First run only, takes a moment…" preferences-system
    # mono/gecko are suppressed only for this bootstrap (their download
    # dialogs are the popups this runner exists to avoid); the real things
    # are installed unattended right after by install_components
    _silent_wineboot -i || die "Windows environment setup failed" "See $LOG"
    "$RUNNER_DIR/bin/wineserver" -w
    _quiet_runtime_ui
    link_filesystem
}

# Make the Linux filesystem a first-class citizen inside Windows:
#   - the profile's Documents/Downloads/Desktop/… point at the real XDG
#     dirs, so what a program saves to "Documents" lands in ~/Documents and
#     files you already have are visible to Save/Open dialogs
#   - H:\ is the whole home directory; Z:\ (Wine's default) stays as / so
#     any absolute Linux path is reachable, e.g. a tool like FolderChangesView
#     can watch H:\Projects or Z:\etc directly
link_filesystem() {
    local profile
    profile=$(ls -d "$WINEPREFIX/drive_c/users/"*/ 2>/dev/null | grep -viE '/Public/$' | head -1)
    [ -n "$profile" ] || profile="$WINEPREFIX/drive_c/users/steamuser/"

    link_dir "$profile/Desktop" "${XDG_DESKTOP_DIR:-$HOME/Desktop}"
    link_dir "$profile/Documents" "${XDG_DOCUMENTS_DIR:-$HOME/Documents}"
    link_dir "$profile/Downloads" "${XDG_DOWNLOAD_DIR:-$HOME/Downloads}"
    link_dir "$profile/Pictures" "${XDG_PICTURES_DIR:-$HOME/Pictures}"
    link_dir "$profile/Music" "${XDG_MUSIC_DIR:-$HOME/Music}"
    link_dir "$profile/Videos" "${XDG_VIDEOS_DIR:-$HOME/Videos}"

    ln -sfn "$HOME" "$WINEPREFIX/dosdevices/h:"
}

# Replace an in-prefix folder with a symlink to its real Linux counterpart,
# but never destroy files: if the Windows folder already holds data, move it
# into the target first
link_dir() {
    local win=$1 real=$2
    [ -L "$win" ] && return 0
    mkdir -p "$real"
    if [ -d "$win" ]; then
        find "$win" -mindepth 1 -maxdepth 1 -exec mv -n {} "$real/" \; 2>/dev/null
        rmdir "$win" 2>/dev/null || rm -rf "$win"
    fi
    ln -sfn "$real" "$win"
}

install_bindings() {
    [ "$(cat "$BASE/bindings.version" 2>/dev/null)" = "$BINDINGS_VER" ] && return 0
    local wt="$RUNNER_DIR/bin/winetricks"
    if [ ! -x "$wt" ]; then
        fetch "$WINETRICKS_URL" "$WINETRICKS_SHA256" "$wt"
        chmod +x "$wt"
    fi
    # Per-verb ledger: a verb that already succeeded is never re-attempted, so
    # one persistently flaky verb (a down mirror) can't drag every launch back
    # through the whole set — only the missing verbs retry.
    local done_file="$BASE/bindings.done"
    touch "$done_file"
    local pending=""
    local verb
    for verb in $WINETRICKS_VERBS; do
        grep -qxF "$verb" "$done_file" || pending="$pending $verb"
    done
    [ -n "$pending" ] || { echo "$BINDINGS_VER" > "$BASE/bindings.version"; return 0; }

    say "installing runtime libraries (VC++ runtimes, core fonts, D3D compiler)..."
    notify "Installing Windows runtime libraries" "One-time: the runtimes most programs expect…" folder-download
    # winetricks must use this runner, not any system wine; --unattended
    # answers every installer dialog. One verb at a time so a single failure
    # doesn't take the rest down.
    for verb in $pending; do
        say "  · $verb"
        if env WINE="$WINE" WINESERVER="$RUNNER_DIR/bin/wineserver" PATH="$RUNNER_DIR/bin:$PATH" \
            "$wt" -q --unattended "$verb" >>"$LOG" 2>&1; then
            echo "$verb" >> "$done_file"
        else
            say "    ($verb skipped — will retry on a later setup)"
        fi
    done
    "$RUNNER_DIR/bin/wineserver" -w

    # Stamp as fully done only when the ledger covers the whole set
    local missing=""
    for verb in $WINETRICKS_VERBS; do
        grep -qxF "$verb" "$done_file" || missing="$missing $verb"
    done
    [ -n "$missing" ] || echo "$BINDINGS_VER" > "$BASE/bindings.version"
    say "runtime libraries ready"
}

_dll_native() { # dll...
    for dll in "$@"; do
        "$WINE" reg add 'HKCU\Software\Wine\DllOverrides' /v "$dll" /d native /f >>"$LOG" 2>&1
    done
}

install_components() {
    [ "$(cat "$BASE/components.version" 2>/dev/null)" = "$COMPONENTS_VER" ] && return 0
    notify "Installing Windows components" "One-time: .NET, HTML and Direct3D support (~150 MB)…" folder-download
    local tmp="$BASE/components.tmp"
    rm -rf "$tmp"
    mkdir -p "$tmp"

    say "installing .NET support..."
    fetch "$MONO_URL" "$MONO_SHA256" "$tmp/mono.msi"
    "$WINE" msiexec /i "$tmp/mono.msi" /qn >>"$LOG" 2>&1 || die ".NET support install failed" "See $LOG"

    say "installing embedded HTML support..."
    fetch "$GECKO_URL-x86_64.msi" "$GECKO64_SHA256" "$tmp/gecko64.msi"
    fetch "$GECKO_URL-x86.msi" "$GECKO32_SHA256" "$tmp/gecko32.msi"
    "$WINE" msiexec /i "$tmp/gecko64.msi" /qn >>"$LOG" 2>&1 || die "HTML support install failed" "See $LOG"
    "$WINE" msiexec /i "$tmp/gecko32.msi" /qn >>"$LOG" 2>&1 || die "HTML support (32-bit) install failed" "See $LOG"

    if vulkan_ok; then
        say "installing DXVK $DXVK_VER (Direct3D 8-11 over Vulkan)..."
        fetch "$DXVK_URL" "$DXVK_SHA256" "$tmp/dxvk.tar.gz"
        tar -xzf "$tmp/dxvk.tar.gz" -C "$tmp" || die "DXVK unpack failed" "See $LOG"
        cp "$tmp/dxvk-$DXVK_VER/x64/"*.dll "$WINEPREFIX/drive_c/windows/system32/"
        cp "$tmp/dxvk-$DXVK_VER/x32/"*.dll "$WINEPREFIX/drive_c/windows/syswow64/"
        _dll_native d3d8 d3d9 d3d10core d3d11 dxgi

        say "installing VKD3D-Proton $VKD3D_VER (Direct3D 12 over Vulkan)..."
        fetch "$VKD3D_URL" "$VKD3D_SHA256" "$tmp/vkd3d.tar.zst"
        tar --zstd -xf "$tmp/vkd3d.tar.zst" -C "$tmp" || die "VKD3D unpack failed" "See $LOG"
        cp "$tmp/vkd3d-proton-$VKD3D_VER/x64/"*.dll "$WINEPREFIX/drive_c/windows/system32/"
        cp "$tmp/vkd3d-proton-$VKD3D_VER/x86/"*.dll "$WINEPREFIX/drive_c/windows/syswow64/"
        _dll_native d3d12 d3d12core
    else
        say "no Vulkan driver found - skipping DXVK/VKD3D, Direct3D runs on OpenGL"
    fi

    # Windows leaves fonts jagged by default; every desktop expects smoothing
    "$WINE" reg add 'HKCU\Control Panel\Desktop' /v FontSmoothing /d 2 /f >>"$LOG" 2>&1
    "$WINE" reg add 'HKCU\Control Panel\Desktop' /v FontSmoothingType /t REG_DWORD /d 2 /f >>"$LOG" 2>&1
    "$RUNNER_DIR/bin/wineserver" -w
    rm -rf "$tmp"
    echo "$COMPONENTS_VER" > "$BASE/components.version"
    notify "Windows apps ready" "Runner, .NET, HTML and Direct3D support installed" checkmark
}

ensure_ready() {
    # Two rapid double-clicks must not race the setup; the second waits on
    # the lock, finds everything ready and runs normally. An explicit --setup
    # forces the update check past its daily throttle (the user asked now).
    exec 9> "$BASE/.setup.lock"
    flock 9
    install_runner
    check_runner_update "${1:-}"
    init_prefix
    install_components
    link_filesystem   # cheap + idempotent; also upgrades pre-existing prefixes
    install_bindings
    flock -u 9
}

# Kill any lingering instances of THIS program before launching. Stale copies
# from an earlier crashed/hung/force-killed run pile up and poison the next
# launch: a single-instance app (Telegram) then aborts on the contended lock/
# socket (exit 9) instead of starting. Wine names each process after its exe
# (comm, truncated to 15 chars), so an exact-comm kill hits only this program's
# own processes — never polycarbon itself or other apps in the prefix.
kill_stale() { # exe-basename
    local comm; comm=$(printf '%s' "$1" | cut -c1-15)
    pgrep -x "$comm" >/dev/null 2>&1 || return 0
    # A LIVE session is not stale. Wine maps app windows with class = the exe
    # basename, so if this exe has a window up right now the user is simply
    # running it — launching it again (double-click, .lnk, file handoff) must
    # not shoot the session. Only windowless leftovers are zombies.
    if command -v hyprctl >/dev/null 2>&1 \
        && hyprctl clients -j 2>/dev/null | grep -iq "\"class\": *\"$1\""; then
        logmsg "$1 already has a window open — not touching the running session"
        return 0
    fi
    logmsg "clearing stale instances of $1"
    pkill -x "$comm" 2>/dev/null
    sleep 1
    pkill -9 -x "$comm" 2>/dev/null
}

# Wine persists every audio endpoint it ever saw into the prefix registry
# (HKLM\...\MMDevices\Audio). On hosts where endpoints come and go — display
# audio sinks that follow monitors, per-PID virtual sinks from capture apps —
# that cache fills with entries whose device no longer exists, and programs
# that enumerate audio devices at startup (Telegram/WebRTC and friends) hit a
# stack-buffer overrun (__fastfail c0000409, no window) on the stale data.
# Proven by bisect both ways: poisoned prefix minus this tree launches clean,
# clean prefix plus this tree crashes. Dropping the tree is safe — Wine
# rebuilds it from the LIVE device set the moment the app initialises audio;
# the only cost is that a non-default output picked inside an app doesn't
# stick across launches. Skipped while other prefix apps run — clearing
# devices under a live session is worse than a stale cache, and the running
# app proves the current cache is harmless anyway.
clear_audio_endpoint_cache() {
    _prefix_busy && return 0
    "$WINE" reg delete 'HKLM\Software\Microsoft\Windows\CurrentVersion\MMDevices\Audio' /f >/dev/null 2>&1
    return 0
}

# A GUI program that neither opens a window nor exits is HUNG (a graphics
# deadlock on a multi-GPU box does exactly this) — recovery can only help if
# we stop waiting on it. run_with_watchdog launches the program and watches
# for one of three outcomes: a window appears (it works — wait for the user to
# close it, so installers still harvest), everything exits (it crashed/
# finished — diagnose), or the grace window passes with no window and it's
# still alive (hung — kill it and report 124 so recovery moves on). Installers
# legitimately run windowless, so they skip the watchdog and just block.
WATCHDOG_GRACE=${POLYCARBON_GRACE:-40}

_win_addrs() {
    command -v hyprctl >/dev/null 2>&1 || return 0
    hyprctl clients -j 2>/dev/null | grep -oE '"address": *"[^"]+"' | sort -u
}

_new_window_since() { # $1 = window addresses captured before launch
    [ -n "$(comm -13 <(printf '%s\n' "$1") <(_win_addrs) 2>/dev/null)" ]
}

_prefix_busy() { pgrep -f "$RUNNER_DIR/bin/wine" >/dev/null 2>&1; }

is_installer() {
    case "${1,,}" in
    *.msi) return 0 ;;
    *setup*|*install*|*_inst.exe|*inst.exe) return 0 ;;
    esac
    return 1
}

# $1 learned-env, $2 rung-env. Reads $target/$exe/$appargs from the caller
# (bash dynamic scope). Returns 0 = ran/worked, 124 = hung, else exit code.
run_with_watchdog() {
    local learned=$1 extra=$2
    local before; before=$(_win_addrs)
    ( eval "$learned"; eval "$extra"; run_target "$target" "${appargs[@]}" ) &
    local launcher=$! t=0
    while :; do
        if _new_window_since "$before"; then
            wait "$launcher" 2>/dev/null      # window up: real session, block till closed
            "$RUNNER_DIR/bin/wineserver" -w 2>/dev/null
            return 0
        fi
        if ! kill -0 "$launcher" 2>/dev/null; then
            # The launcher exiting doesn't mean the program is gone: single-
            # instance apps (Telegram, Vortex) forward to their running copy
            # and quit, and some apps re-exec themselves. If the program is
            # still alive after its launcher left, that's a working session —
            # judging it "no new window = hung" here is what shot a live
            # Vortex (wineserver -k takes the whole prefix with it).
            sleep 2                            # let a dying app's procs drain
            if _app_alive; then
                wait "$launcher" 2>/dev/null
                return 0
            fi
            if ! _prefix_busy; then
                wait "$launcher"; return $?    # fully exited, nothing lingering
            fi
        fi
        if [ "$t" -ge "$WATCHDOG_GRACE" ]; then
            logmsg "$exe never opened a window in ${WATCHDOG_GRACE}s and is still running — treating as hung"
            "$RUNNER_DIR/bin/wineserver" -k >/dev/null 2>&1
            wait "$launcher" 2>/dev/null
            return 124
        fi
        sleep 1; t=$((t + 1))
    done
}

run_target() {
    local target=$1
    shift
    cd "$(dirname "$target")" || exit 1
    case "${target,,}" in
    *.msi)
        "$WINE" msiexec /i "$target" "$@" >>"$LOG" 2>&1
        ;;
    *.lnk)
        "$WINE" start /wait /unix "$target" >>"$LOG" 2>&1
        ;;
    *.bat | *.cmd)
        "$WINE" cmd /c "$(winpath "$target")" "$@" >>"$LOG" 2>&1
        ;;
    *.vbs | *.vbe | *.wsf)
        "$WINE" wscript "$(winpath "$target")" "$@" >>"$LOG" 2>&1
        ;;
    *.reg)
        # regedit shows the standard import-confirmation, same as Windows
        "$WINE" regedit "$(winpath "$target")" >>"$LOG" 2>&1
        ;;
    *)
        "$WINE" "$target" "$@" >>"$LOG" 2>&1
        ;;
    esac
}

# cmd/wscript/regedit want Windows-style paths; winepath translates any Linux
# path through the drive mappings (H:\, Z:\, …)
winpath() {
    "$WINE" winepath -w "$1" 2>/dev/null
}

# Route a browser URI to the program that registered its scheme. Wine's
# `start`/ShellExecute fails outright on custom schemes ("General failure"),
# so resolve the handler command from the registry and launch it directly.
# The registered command (e.g. "…\Vortex.exe" "%1") is tokenised the Windows
# way and %1 replaced with the whole URI as ONE argv element — query strings
# (?a=1&b=2) then reach the program intact instead of the shell splitting on &.
dispatch_url() {
    local uri=$1 scheme=${1%%://*} cmd root
    for root in 'HKEY_CURRENT_USER\Software\Classes' 'HKEY_LOCAL_MACHINE\Software\Classes' 'HKEY_CLASSES_ROOT'; do
        cmd=$("$WINE" reg query "$root\\$scheme\\shell\\open\\command" /ve 2>/dev/null | sed -n 's/.*REG_SZ[[:space:]]*//p' | tr -d '\r')
        [ -n "$cmd" ] && break
    done
    if [ -z "$cmd" ]; then
        notify "Link not handled" "No Windows program is registered for $scheme:// links"
        return 1
    fi
    local -a argv
    mapfile -d '' -t argv < <(python3 -c '
import sys
cmd, uri = sys.argv[1], sys.argv[2]
toks, cur, inq = [], "", False
for ch in cmd:
    if ch == "\"": inq = not inq
    elif ch == " " and not inq:
        if cur: toks.append(cur); cur = ""
    else: cur += ch
if cur: toks.append(cur)
# a bare %1 token becomes the whole URI; embedded %1 (rare) is substituted
sys.stdout.write("\0".join((uri if t == "%1" else t.replace("%1", uri)) for t in toks))
' "$cmd" "$uri")

    # Launch from the handler program's OWN directory. This is what makes the
    # app's single-instance handoff work: a portable app (Vortex, Telegram…)
    # keeps its running-instance lock/socket next to the exe or in a data dir
    # it resolves relative to the working directory, so launching a link from
    # the wrong cwd makes the second copy fail to see the first and open a
    # brand-new window every time. Matching run_target's cwd lets the second
    # copy find the first, forward the URI, and exit — like on Windows.
    local exe_unix exe_dir
    exe_unix=$("$WINE" winepath -u "${argv[0]}" 2>/dev/null)
    exe_dir=$(dirname "$exe_unix" 2>/dev/null)
    if [ -n "$exe_dir" ] && [ -d "$exe_dir" ]; then
        logmsg "routing link to $(basename "${argv[0]}") (cwd: ${exe_dir})"
        ( cd "$exe_dir" && "$WINE" "${argv[@]}" >>"$LOG" 2>&1 )
    else
        "$WINE" "${argv[@]}" >>"$LOG" 2>&1
    fi
}

# The directories an installer drops shortcuts into
_shortcut_roots() {
    local profile
    profile=$(ls -d "$WINEPREFIX/drive_c/users/"*/ 2>/dev/null | grep -viE '/Public/$' | head -1)
    [ -n "$profile" ] || profile="$WINEPREFIX/drive_c/users/steamuser/"
    printf '%s\n' \
        "$WINEPREFIX/drive_c/ProgramData/Microsoft/Windows/Start Menu" \
        "$profile/AppData/Roaming/Microsoft/Windows/Start Menu" \
        "$profile/Desktop" \
        "$WINEPREFIX/drive_c/users/Public/Desktop"
}

_list_shortcuts() {
    local root
    _shortcut_roots | while IFS= read -r root; do
        [ -e "$root" ] && find -L "$root" -iname '*.lnk' 2>/dev/null
    done | sort -u
}

# Turn every Start Menu / Desktop shortcut an installer just created into a
# real Linux launcher that runs through Polycarbon, so installed Windows
# programs land in the app menu exactly like they do on Windows. Called with
# the shortcut listing captured before the run; only genuinely new entries
# are registered, and icons extracted by Wine's own menu builder are reused.
harvest_shortcuts() {
    local before=$1 lnk name slug dest icon
    mkdir -p "$APPS_DIR"
    while IFS= read -r lnk; do
        [ -n "$lnk" ] || continue
        grep -qxF "$lnk" "$before" 2>/dev/null && continue
        name=$(basename "$lnk" .lnk)
        # Wine's own uninstaller entries are noise, not apps
        case "$name" in *[Uu]ninstall*) continue ;; esac
        slug=$(printf '%s' "$name" | tr -cs '[:alnum:]' '-' | tr '[:upper:]' '[:lower:]' | sed 's/^-//;s/-$//')
        [ -n "$slug" ] || continue
        dest="$APPS_DIR/polycarbon-$slug.desktop"
        icon=$(_find_wine_icon "$name")
        cat > "$dest" <<EOF
[Desktop Entry]
Type=Application
Name=$name
Comment=Windows program via Polycarbon
Exec="$SELF" "$lnk"
Icon=${icon:-application-x-executable}
Terminal=false
Categories=Utility;
X-Polycarbon=true
EOF
        notify "$name installed" "Added to your app menu" checkmark
    done < <(_list_shortcuts)
    # The runtime's own menu builder writes runner-branded duplicates under
    # applications/wine/. Its extracted ICONS live separately in the icon
    # theme and stay usable; the branded entries themselves are removed so
    # only Polycarbon's launchers ever appear in the app menu.
    rm -rf "$APPS_DIR/wine"
    command -v update-desktop-database >/dev/null && update-desktop-database "$APPS_DIR" 2>/dev/null || true
}

# Wine's winemenubuilder extracts each shortcut's real icon and writes its own
# launcher under applications/wine/; steal that Icon line so our menu entry
# looks right instead of falling back to a generic glyph
_find_wine_icon() {
    local name=$1 winedir="${XDG_DATA_HOME:-$HOME/.local/share}/applications/wine"
    [ -d "$winedir" ] || return 0
    grep -rlxF "Name=$name" "$winedir" 2>/dev/null | head -1 | xargs -r grep -m1 '^Icon=' | cut -d= -f2-
}

# URL protocols Windows programs register (vortex://, nxm://, …) live only in
# the prefix registry — a Linux browser never sees them. Bridge each one to a
# Linux scheme handler that routes the link back here (--url), so "open in
# app" buttons on websites reach the Windows program like they would on
# Windows. Web/system schemes are never touched, and a scheme some Linux app
# already handles is left alone (native Steam keeps steam://, and so on).
harvest_schemes() {
    local reg scheme handler entry
    for scheme in $(awk '
        /^\[/ { sec = $0 }
        /"URL Protocol"/ {
            if (sec ~ /^\[Software\\\\Classes\\\\[a-zA-Z][a-zA-Z0-9+.-]*\]/) {
                sub(/^\[Software\\\\Classes\\\\/, "", sec)
                sub(/\].*/, "", sec)
                print tolower(sec)
            }
        }' "$WINEPREFIX/system.reg" "$WINEPREFIX/user.reg" 2>/dev/null | sort -u); do
        case "$scheme" in
        http | https | ftp | ftps | file | mailto | news | nntp | irc | ircs | tel | sms | about | javascript | res | mk | ms-* | microsoft* | windows* | x-scheme-handler*)
            continue
            ;;
        esac
        entry="polycarbon-scheme-$scheme.desktop"
        handler=$(xdg-mime query default "x-scheme-handler/$scheme" 2>/dev/null)
        [ -n "$handler" ] && [ "$handler" != "$entry" ] && continue
        [ -f "$APPS_DIR/$entry" ] && [ "$handler" = "$entry" ] && continue
        cat > "$APPS_DIR/$entry" <<EOF
[Desktop Entry]
Type=Application
Name=${scheme^} link (Polycarbon)
Comment=Opens $scheme:// links in the Windows program that registered them
Exec="$SELF" --url %u
Icon=application-x-executable
Terminal=false
NoDisplay=true
MimeType=x-scheme-handler/$scheme;
EOF
        xdg-mime default "$entry" "x-scheme-handler/$scheme"
        notify "${scheme^} links connected" "$scheme:// links from your browser now open the Windows program" checkmark
    done
}

main() {
    [ $# -ge 1 ] || die "Nothing to run" "polycarbon expects a .exe, .msi or .lnk path"

    # System-scan fix path: full setup now, run nothing. Forces the runtime
    # update check so "Set up / Update" in the scan always fetches the latest.
    if [ "$1" = "--setup" ]; then
        SETUP_MODE=1
        new_log
        ensure_ready force
        harvest_schemes
        say "ready - double-click any .exe"
        exit 0
    fi

    # Browser protocol launch (vortex://…): hand the URI to the handler the
    # Windows program registered inside the prefix. The runtime is necessarily
    # already installed (you can't register a scheme without first running the
    # program), so skip setup entirely — going through ensure_ready here would
    # block on the running app's setup lock and delay the handoff.
    if [ "$1" = "--url" ]; then
        shift
        [ $# -ge 1 ] || die "Nothing to open" "no link given"
        [ -x "$WINE" ] || die "Windows apps not set up yet" "Run the program once before its links work"
        new_log
        logmsg "opening link: $1"
        dispatch_url "$1"
        local ucode=$?
        local uerr; uerr=$(salient_error)
        [ -n "$uerr" ] && notify "Link failed" "$uerr
Full log: $LOG" dialog-error
        exit "$ucode"
    fi

    local target
    target=$(realpath "$1")
    shift

    new_log
    [ -e "$target" ] || die "File not found" "$target"
    logmsg "launching $(basename "$target")"
    # Clear leftover instances of THIS program up front, before setup runs:
    # stale copies keep wineserver alive, and the runtime auto-updater defers
    # whenever it sees Wine running — so zombies would block the auto-update
    # forever (the exact reason a runtime got stuck and needed a manual update).
    kill_stale "$(basename "$target")"
    ensure_ready
    clear_audio_endpoint_cache

    # Bridge protocols the program registered on a previous run/install BEFORE
    # launching it — a long-lived app (Vortex, Telegram…) never "exits" to
    # trigger the after-run harvest, so its browser-link handler has to be
    # live while it runs, not after
    harvest_schemes
    # A first-ever launch registers its scheme mid-startup; catch that too,
    # from a detached watcher, without blocking the app
    ( sleep 8; harvest_schemes ) >/dev/null 2>&1 &

    # Snapshot existing shortcuts so an installer's new ones can be spotted
    local before="$BASE/.shortcuts.pre"
    _list_shortcuts > "$before"

    # Marker so we can later tell which log/dump files THIS run produced
    local marker="$BASE/.launch-marker"
    : > "$marker"

    local exe; exe=$(basename "$target")
    local -a appargs=("$@")
    local qf="$QUIRKS_DIR/$exe.env"
    mkdir -p "$QUIRKS_DIR"
    # Hygiene: saved fixes from the removed virtual-desktop experiment are
    # dead env now — drop them so "applying saved fix" logs stay truthful.
    sed -i '/POLYCARBON_VDESKTOP/d' "$QUIRKS_DIR"/*.env 2>/dev/null
    find "$QUIRKS_DIR" -maxdepth 1 -name '*.env' -empty -delete 2>/dev/null
    # Prevention: a fix learned on a past run is applied from the very first
    # launch, so a program that once crashed just starts.
    local learned=""
    [ -f "$qf" ] && { learned=$(cat "$qf"); logmsg "applying saved fix for $exe: $(tr '\n' ';' <"$qf")"; }

    # The recovery ladder: each rung is a Wine quirk tried in its own restart.
    # "" = as-is (with any learned fix); the rest are attempted only if their
    # guard matches the crash, most-likely first, then everything combined.
    local -a ladder=("" gpu_prime dxvk_off wgi_off fsync_off combined gpu_soft)
    local code started err failed step extra had_app_logs=""
    local -a tried=()
    # Guards read the signature of the LAST crash; each attempt is judged on
    # its OWN output slice, so an earlier crash's error never taints a later
    # working attempt.
    local slice="$BASE/.attempt.log" crash_slice="$LOG" rung_start

    for step in "${ladder[@]}"; do
        if [ -n "$step" ]; then
            recovery_guard "$step" "$crash_slice" || continue
            extra=$(recovery_env "$step" "$crash_slice")
            [ -n "$extra" ] || continue
            tried+=("$step")
            logmsg "recovery: restarting $exe with fix '$step' ($(recovery_human "$step"))"
            notify "Recovering $exe" "Trying to $(recovery_human "$step")…" preferences-system
        else
            extra=""
        fi

        : > "$marker"
        # Each recovery attempt starts from a clean slate: the previous
        # attempt's process is cleared so a single-instance app doesn't abort
        # on a still-contended lock when it relaunches.
        [ -n "$step" ] && kill_stale "$exe"
        rung_start=$(wc -l <"$LOG" 2>/dev/null || echo 0)
        started=$SECONDS
        # Installers run windowless and exit on their own — block on them.
        # Everything else goes through the watchdog so a hang can't stall us.
        if is_installer "$target"; then
            ( eval "$learned"; eval "$extra"; run_target "$target" "${appargs[@]}" )
            code=$?
            "$RUNNER_DIR/bin/wineserver" -w 2>/dev/null
        else
            run_with_watchdog "$learned" "$extra"
            code=$?
        fi
        logmsg "$exe finished/settled with code $code after $((SECONDS - started))s"

        had_app_logs=""
        collect_app_logs "$(dirname "$target")" "$marker" && had_app_logs=1
        # This attempt's output only — everything the log grew by since launch
        tail -n +$((rung_start + 1)) "$LOG" > "$slice" 2>/dev/null
        err=$(salient_error "$slice")
        # A failure worth recovering from is one where the program never got
        # going: it hung (124), or it exited fast with an error/nonzero code.
        # A clean exit, or a nonzero after a real windowed session, is a normal
        # quit and must not trigger restarts.
        failed=""
        if [ "$code" = 124 ] || { [ $((SECONDS - started)) -lt 15 ] && { [ -n "$err" ] || [ "$code" -ne 0 ]; }; }; then
            failed=1
            crash_slice="$slice.crash"
            cp -f "$slice" "$crash_slice" 2>/dev/null   # stable copy for the next guard
            [ "$code" = 124 ] && logmsg "FAILED: hung with no window"
            [ -n "$err" ] && logmsg "FAILED: $err"
        fi

        if [ -z "$failed" ]; then
            # It worked. If a rung fixed it, remember it so next time is clean.
            if [ -n "$step" ]; then
                printf '%s\n' "$extra" >> "$qf"
                logmsg "recovered with '$step' — saved so $exe starts clean next time"
                notify "$exe fixed" "$(recovery_human "$step" | sed 's/^./\U&/') — it'll start normally from now on." checkmark
            fi
            break
        fi
    done

    # Exhausted the ladder — capture the REAL cause with full diagnostics, then
    # surface everything in one place.
    if [ -n "$failed" ]; then
        diagnose_failure
        write_failure_report "$exe" "$code" "${tried[*]}" "$crash_slice"
        local report; report=$(salient_error "$crash_slice")
        [ -z "$report" ] && report=$(cat "$BASE/.diag-summary" 2>/dev/null)
        [ -z "$report" ] && [ "$code" = 124 ] && report="Kept hanging with no window."
        notify "$exe couldn't be recovered" "${report:-Exited with code $code, no window.}
Tried: ${tried[*]:-none}. Full details: $LOG" dialog-error
    fi

    # Everything on the prefix has already been waited out; register any
    # shortcuts and protocols the run left behind
    harvest_shortcuts "$before"
    harvest_schemes
    exit "$code"
}

# The normal run is silent (WINEDEBUG=-all) for clean logs. When nothing could
# recover a program, that silence hides the reason — so run it ONE more time
# with full Wine diagnostics on and capture what actually happened: a crash
# and its backtrace (which module/function faulted), an unimplemented API call,
# a device/display error, or — if none of that — the fact that it exited on its
# own with no error (a deliberate quit, not a crash). Reads $target/$exe/
# $appargs/$learned from the caller (bash dynamic scope).
diagnose_failure() {
    logmsg "no fix worked — running one diagnostic pass with full logging to capture the cause"
    kill_stale "$exe"
    local dlog="$BASE/diagnostic.log" dir
    dir=$(dirname "$target")
    : > "$dlog"
    local before_dumps; before_dumps=$(find "$dir" -iname '*.dmp' 2>/dev/null | sort)
    (
        cd "$dir" || exit 1
        eval "$learned"
        # err+all: every real error, including the unhandled-exception report
        # and its backtrace (which module/function faulted). fixme+all: every
        # unimplemented call — the last few before a deliberate quit are the
        # clue for why the program gave up. (No +seh: its trace floods the log.)
        export WINEDEBUG="err+all,fixme+all"
        timeout "$WATCHDOG_GRACE" "$WINE" "$target" "${appargs[@]}"
    ) >"$dlog" 2>&1
    "$RUNNER_DIR/bin/wineserver" -k 2>/dev/null

    # Real failure signals: unhandled exceptions + their backtrace, module/load
    # errors, wine diagnostics, assertions. (Plain err: lines, not fixme noise.)
    local hits
    hits=$(grep -anE 'err:|Unhandled exception|[Bb]acktrace:|assertion|[Ff]atal error|Call to unimplemented' "$dlog" 2>/dev/null | tail -30)
    # A crash the app caught itself (Breakpad) leaves a minidump but no Wine
    # error — decode it if the tooling is around, else at least name it.
    local newdump; newdump=$(comm -13 <(printf '%s\n' "$before_dumps") <(find "$dir" -iname '*.dmp' 2>/dev/null | sort) | head -1)

    {
        echo "--- diagnostic run (full Wine logging) ---"
        if [ -n "$hits" ]; then
            printf '%s\n' "$hits"
        elif [ -n "$newdump" ]; then
            echo "the program crashed and caught it itself (minidump: ${newdump##*/})"
            if command -v minidump_stackwalk >/dev/null 2>&1; then
                minidump_stackwalk "$newdump" 2>/dev/null | grep -aiE 'crash reason|crash address|^ ?0 ' | head -8
            fi
        else
            echo "Wine emitted no error and no crash was caught — the program exited on its own (a deliberate quit, not a crash). Its final output before exiting:"
            grep -avE 'fixme:' "$dlog" | tail -20
            echo "…last unimplemented calls it hit (a clue to what it couldn't do):"
            grep -aE 'fixme:' "$dlog" | tail -8
        fi
        echo "--- full diagnostic log: $dlog ---"
    } >> "$LOG"

    # One-line takeaway for the notification
    if [ -n "$hits" ]; then
        printf '%s' "$hits" | grep -aiE 'exception|:err:|assertion|fatal|unimplemented' | tail -1 | sed 's/^[0-9]*://;s/^[[:space:]]*//' | cut -c1-200 > "$BASE/.diag-summary"
    elif [ -n "$newdump" ]; then
        echo "Crashed internally (caught by its own handler) — see the diagnostic log." > "$BASE/.diag-summary"
    else
        echo "Exited on its own — a deliberate quit, not a crash. See the diagnostic log for its last activity." > "$BASE/.diag-summary"
    fi
}

# When recovery gives up, dump a verbose, self-contained diagnostic block into
# the log: the exact fixes attempted, the GPUs seen, the runtime/version, and
# every crash dump found — so one look at last-run.log tells the whole story.
write_failure_report() { # exe code tried crash-slice
    {
        echo "========================================================"
        echo "polycarbon failure report — $1"
        echo "runtime: $(cat "$BASE/runner.version" 2>/dev/null)   exit code: $2"
        echo "recovery fixes attempted: ${3:-none}"
        grep -aoE '^info:  Found device: .*' "$LOG" | sed 's/^info:  /GPU: /' | sort -u
        local dline; dline=$(salient_error "${4:-$LOG}"); [ -z "$dline" ] && dline=$(cat "$BASE/.diag-summary" 2>/dev/null)
        echo "what went wrong: ${dline:-unknown — see the diagnostic section above}"
        echo "if this is a game/GPU app, editing $POLY_ENV by hand can help — see the notes in it"
        echo "========================================================"
    } >> "$LOG"
}

main "$@"
